Subject: [PATCH 08/18] Wire up intersection detection and jump rendering
 (FUNCTIONAL!)

---
 .../gfx/connector/src/connector-watcher.ts    | 31 +++++++++++++
 blocksuite/affine/gfx/connector/src/index.ts  |  2 +
 .../connector/src/renderer/dom-renderer.ts    | 45 ++++++++++++++-----
 .../model/src/elements/connector/connector.ts |  9 ++++
 4 files changed, 76 insertions(+), 11 deletions(-)

diff --git a/blocksuite/affine/gfx/connector/src/connector-watcher.ts b/blocksuite/affine/gfx/connector/src/connector-watcher.ts
index 0d1a8c2387..8cc73c6616 100644
--- a/blocksuite/affine/gfx/connector/src/connector-watcher.ts
+++ b/blocksuite/affine/gfx/connector/src/connector-watcher.ts
@@ -7,6 +7,7 @@ import type { ConnectorElementModel } from '@blocksuite/affine-model';
 import type { GfxModel } from '@blocksuite/std/gfx';
 
 import { ConnectorPathGenerator } from './connector-manager';
+import { updateConnectorJumps as calculateConnectorJumps } from './jump-calculator';
 
 export const connectorWatcher: SurfaceMiddleware = (
   surface: SurfaceBlockModel
@@ -25,6 +26,31 @@ export const connectorWatcher: SurfaceMiddleware = (
       ConnectorPathGenerator.updatePath(connector, null, elementGetter);
     }
   };
+
+  /**
+   * Update jump points for connectors with jump styles enabled.
+   * Calculates intersections between connectors and stores routed points.
+   */
+  const updateJumpsForConnectors = (connectors: Set<ConnectorElementModel>) => {
+    const allConnectors = Array.from(
+      surface.getElementsByType('connector')
+    ) as ConnectorElementModel[];
+
+    connectors.forEach(connector => {
+      if (
+        connector.jumpStyle !== 'none' &&
+        connector.absolutePath.length >= 2
+      ) {
+        // Calculate jump points based on intersections
+        const routedPoints = calculateConnectorJumps(connector, allConnectors);
+        connector.routedPoints = routedPoints.length > 0 ? routedPoints : null;
+      } else {
+        // Clear jump points if jump style is disabled
+        connector.routedPoints = null;
+      }
+    });
+  };
+
   const pendingList = new Set<ConnectorElementModel>();
   let pendingFlag = false;
   const addToUpdateList = (connector: ConnectorElementModel) => {
@@ -33,7 +59,12 @@ export const connectorWatcher: SurfaceMiddleware = (
     if (!pendingFlag) {
       pendingFlag = true;
       queueMicrotask(() => {
+        // First update all connector paths
         pendingList.forEach(updateConnectorPath);
+
+        // Then calculate jumps for connectors that need them
+        updateJumpsForConnectors(pendingList);
+
         pendingList.clear();
         pendingFlag = false;
       });
diff --git a/blocksuite/affine/gfx/connector/src/index.ts b/blocksuite/affine/gfx/connector/src/index.ts
index 7d87973a6e..2edb6c4f79 100644
