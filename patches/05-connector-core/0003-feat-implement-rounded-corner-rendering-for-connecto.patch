+    } else if (rounded && points.length > 2) {
+      // Render path with rounded corners at bend points
+      const radius = cornerRadius ?? 20;
+      ctx.moveTo(points[0][0], points[0][1]);
+      for (let i = 1; i < points.length - 1; i++) {
