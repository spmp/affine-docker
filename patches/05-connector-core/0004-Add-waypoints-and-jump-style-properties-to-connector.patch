 .../model/src/elements/connector/connector.ts | 29 +++++++++++++++++++
 tools/utils/src/workspace.gen.ts              | 14 +++++++++
 yarn.lock                                     | 16 ++++++++++
 4 files changed, 60 insertions(+)

