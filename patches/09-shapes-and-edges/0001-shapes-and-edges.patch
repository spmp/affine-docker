+      const [x, y, w, h] = this.xywh;
+      rc.polygon(
+        [
+          [x + w * 0.25, y],
+          [x + w * 0.75, y],
+          [x + w, y + h / 2],
+          [x + w * 0.75, y + h],
+          [x + w * 0.25, y + h],
+          [x, y + h / 2],
+        ],
+        this.options
+      );
+    } else {
+      drawGeneralShape(ctx, 'hexagon', this.xywh, this.options);
+    }
+  }
+}
