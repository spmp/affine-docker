+  const topY = y + ry;
+  const bottomY = y + h - ry;
+
+  ctx.beginPath();
+  ctx.moveTo(x, topY);
+  ctx.ellipse(x + rx, topY, rx, ry, 0, Math.PI, 0);
+  ctx.lineTo(x + w, bottomY);
+  ctx.ellipse(x + rx, bottomY, rx, ry, 0, 0, Math.PI);
+  ctx.closePath();
+
+  ctx.moveTo(x + rx, topY);
+  ctx.ellipse(x + rx, topY, rx, ry, 0, 0, Math.PI * 2);
+};
