+
+    ctx.setTransform(
+      matrix
+        .translateSelf(renderOffset, renderOffset)
+        .translateSelf(cx, cy)
+        .scaleSelf(flipX ? -1 : 1, flipY ? -1 : 1)
+        .rotateSelf(rotate)
+        .translateSelf(-cx, -cy)
