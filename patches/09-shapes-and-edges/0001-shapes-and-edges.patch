+
+const logicAndPoints = ({ x, y, w, h }: IBound): IVec[] => [
+  [x, y],
+  [x + w, y],
+  [x + w, y + h],
+  [x, y + h],
+];
+
+const drawLogicAnd = (ctx: CanvasRenderingContext2D, bound: IBound) => {
+  const { x, y, w, h } = bound;
+  const r = h / 2;
+
+  ctx.beginPath();
