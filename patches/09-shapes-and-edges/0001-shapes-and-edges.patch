+    x + width * 0.78,
+    y + height * 0.9,
+    x + width * 0.6,
+    y + height * 0.92,
+    x + width * 0.5,
+    y + height * 0.82
+  );
+  ctx.bezierCurveTo(
+    x + width * 0.4,
+    y + height * 0.95,
+    x + width * 0.22,
+    y + height * 0.92,
+    x + width * 0.2,
+    cy + r * 0.7
