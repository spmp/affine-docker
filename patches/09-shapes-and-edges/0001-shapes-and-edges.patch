-        return true;
-      }
-    } else {
-      // Target tail comes from right to shape
-      // Detach if the tail start (adjacent to dragged) is now RIGHT of shape's right edge
-      if (adjacentPoint[0] > shapeBounds.x + shapeBounds.w) {
-        return true;
-      }
-    }
