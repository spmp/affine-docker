+          const keyword = this._searchKeyword.toLowerCase();
+          return (
+            String(shape.name).toLowerCase().includes(keyword) ||
+            (shape.tooltip ?? '').toLowerCase().includes(keyword)
+          );
+        })
+      : SHAPE_BROWSER_ITEMS;
