-    tooltip: 'Rounded rectangle',
-    disabled: false,
-  },
+];
+
+// All shapes combined (for shape browser)
+export const AllShapeConfig: Config[] = [
+  ...ShapeComponentConfig,
+  ...ExtendedShapeConfig,
 ];
 
 export const ShapeComponentConfigMap = ShapeComponentConfig.reduce(
